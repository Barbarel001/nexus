# Copia este archivo a .env y rellena tus valores (docker compose lo carga).
# .env está en .gitignore: NO lo subas al repo.

# --- IA ---
ANTHROPIC_API_KEY=sk-ant-...
# o usa el modo local gratis:  NEXUS_BACKEND=ollama

# --- Seguridad / sesiones (multiusuario) ---
NEXUS_SECRET=pon-aqui-una-clave-larga-y-secreta
NEXUS_BASE_URL=https://tu-dominio.com

# --- Pagos (Stripe) ---
NEXUS_STRIPE_KEY=sk_live_...
NEXUS_STRIPE_PRICE_PRO=price_...
NEXUS_STRIPE_PRICE_TEAM=price_...
NEXUS_STRIPE_WEBHOOK_SECRET=whsec_...

# --- Canales opcionales ---
# NEXUS_TELEGRAM_TOKEN=123456:ABC...
# NEXUS_TELEGRAM_CHAT_ID=tu_chat_id
# NEXUS_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# NEXUS_BRIEFING_HORA=08:00
# NEXUS_CIUDAD=Madrid

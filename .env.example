# ============================================================
#  NEXUS — Plantilla de configuración (.env)
# ------------------------------------------------------------
#  Copia este archivo a «.env» y rellena lo que necesites.
#  TODO es opcional salvo lo marcado [REQUERIDO]. Nada aquí debe
#  contener secretos reales en el repositorio: .env está git-ignored.
#
#    cp .env.example .env
#
#  Carga: exporta estas variables en tu entorno (o usa un gestor de
#  .env como `python-dotenv`/`direnv`/el panel de tu hosting).
# ============================================================

# ---------- Núcleo / IA ----------
# [REQUERIDO si usas Claude] Tu API key de Anthropic.
ANTHROPIC_API_KEY=sk-ant-...
# Backend del modelo: "claude" (API) u "ollama" (local, coste $0).
NEXUS_BACKEND=claude
# Modelo de Claude (claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5).
NEXUS_MODEL=claude-opus-4-8
# Modelo local de Ollama (si NEXUS_BACKEND=ollama; debe estar 'ollama pull'-eado).
NEXUS_OLLAMA_MODEL=qwen2.5:7b
# Host del servidor Ollama.
OLLAMA_HOST=http://localhost:11434
# Modelo de embeddings en Ollama para la búsqueda semántica (RAG real).
NEXUS_EMBED_MODEL=nomic-embed-text
# Longitud máxima de respuesta, en tokens.
NEXUS_MAX_TOKENS=8000
# Cómo quieres que Nexus te llame.
NEXUS_NOMBRE=Señor
# Pedir confirmación antes de comandos/escritura (1 = sí).
NEXUS_CONFIRMAR=1
# Límites de contexto/memoria.
NEXUS_MAX_MENSAJES=40
NEXUS_MAX_NOTAS=200

# ---------- Servidor web ----------
# Interfaz de escucha. 127.0.0.1 = solo esta PC (seguro). 0.0.0.0 = accesible en red.
NEXUS_HOST=127.0.0.1
NEXUS_PORT=5000
# Abrir el navegador automáticamente al arrancar (0 para no).
NEXUS_OPEN=1
# Permitir acciones peligrosas en la web (run_command/write_file) tras confirmar (1 = sí).
NEXUS_WEB_ACCIONES=0
# URL pública base (para los enlaces de Stripe Checkout, etc.).
NEXUS_BASE_URL=http://localhost:5000

# ---------- Seguridad / acceso ----------
# Opción A: una sola contraseña para exponer Nexus fuera de casa.
NEXUS_PASSWORD=
# Opción B: modo multiusuario (cuentas email+contraseña sobre SQLite). 1 = activar.
NEXUS_MULTIUSER=0
# Clave para firmar las sesiones. FIJA Y SECRETA en producción (si vacía, se genera al vuelo).
NEXUS_SECRET=
# Marca la cookie de sesión como Secure (actívalo SOLO tras HTTPS).
NEXUS_HTTPS=0
# Límite de intentos de login por IP y ventana en segundos (anti fuerza bruta).
NEXUS_LOGIN_LIMITE=8
NEXUS_LOGIN_VENTANA=300
# Emails con acceso al panel de administración (separados por comas).
NEXUS_ADMIN_EMAIL=

# ---------- Datos / rutas (déjalas vacías para los valores por defecto) ----------
NEXUS_DB_PATH=
NEXUS_USERS_DIR=
NEXUS_MEMORIA_PATH=
NEXUS_CONV_PATH=
NEXUS_TAREAS_PATH=
NEXUS_ALERTAS_PATH=
NEXUS_GASTOS_PATH=
NEXUS_OPS_PATH=
NEXUS_DOCS_DIR=
NEXUS_LOG=
NEXUS_BACKUP_DIR=
NEXUS_BACKUP_KEEP=14

# ---------- Trading / NinjaTrader ----------
# Carpeta 'incoming' del AT Interface (autodetectada si se deja vacía).
NEXUS_NT_FOLDER=
# Cuenta por defecto. 'Sim101' = simulación (seguro). Pon el nombre EXACTO de tu cuenta real para operar de verdad.
NEXUS_NT_ACCOUNT=Sim101
# Segundos a esperar por el archivo de precio.
NEXUS_NT_ESPERA=2.5
# Modo simulación (1) para probar todo el flujo sin NinjaTrader ni riesgo.
NEXUS_NT_SIMULAR=0
# Bitácora de operaciones.
NEXUS_NT_LOG=
# Gestión de riesgo (0 / vacío = sin límite).
NEXUS_RISK_MAX_QTY=0
NEXUS_RISK_MAX_ORDENES=0
NEXUS_RISK_INSTRUMENTOS=

# ---------- Finanzas / varios ----------
# Símbolo de moneda para mostrar.
NEXUS_MONEDA=$
# Ciudad por defecto para el clima.
NEXUS_CIUDAD=
# Feeds RSS de noticias de mercado (separados por comas).
NEXUS_NEWS_FEEDS=

# ---------- Proactivo / canales ----------
# Bot de Telegram (token de @BotFather) y, opcionalmente, tu chat id.
NEXUS_TELEGRAM_TOKEN=
NEXUS_TELEGRAM_CHAT_ID=
# Webhook de Discord para recibir avisos.
NEXUS_DISCORD_WEBHOOK=
# Scheduler: intervalo de chequeo (segundos), hora del resumen matutino e instrumentos.
NEXUS_SCHED_INTERVALO=60
NEXUS_BRIEFING_HORA=08:00
NEXUS_BRIEFING_INSTRUMENTOS=

# ---------- Google (Calendar + Gmail, opcional) ----------
NEXUS_GOOGLE_CREDENTIALS=credentials.json
NEXUS_GOOGLE_TOKEN=token.json

# ---------- Notificaciones Web Push (opcional; requiere 'pip install pywebpush') ----------
# Genera el par con:  python nexus_push.py genkeys
NEXUS_VAPID_PUBLIC=
NEXUS_VAPID_PRIVATE=
NEXUS_VAPID_SUBJECT=mailto:tu-correo@ejemplo.com
NEXUS_PUSH_SUBS=

# ---------- Pagos / suscripciones (Stripe, opcional) ----------
NEXUS_STRIPE_KEY=
NEXUS_STRIPE_WEBHOOK_SECRET=
NEXUS_STRIPE_PRICE_PRO=
NEXUS_STRIPE_PRICE_TEAM=
